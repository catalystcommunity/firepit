{
  "name": "firepit-webapp",
  "private": true,
  "version": "0.0.0",
  "description": "Firepit SPA client — SolidJS + Vite + CBOR CSIL-RPC",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
