    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "happy-dom": "^20.10.6",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9"
  }
}
