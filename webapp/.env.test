# Vitest runs with Vite's "test" mode, which auto-loads this file (see
# https://vitejs.dev/guide/env-and-mode). Component tests import the
# `~/lib/api` singleton, which picks mock mode up from this exact env var
# (src/lib/api.ts's `isMockModeEnabled`) — so every test gets the seeded
# in-memory fixture store instead of trying real network calls.
VITE_FIREPIT_MOCK=1
