node_modules/
dist/
dist-ssr/
*.local

# Generated code (checked in once task A2 wires codegen — until then these
# dirs only hold .gitkeep; ignore build byproducts codegen may drop here)
webapp/src/gen/*
!webapp/src/gen/.gitkeep

# IDE / editor
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.dev

# Local dev runtime
/logs/
